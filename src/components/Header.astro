---
const navLinks = [
	{ href: '/', label: 'Home' },
	{ href: '/faq', label: 'FAQ' },
	{ href: '/privacy', label: 'Privacy Policy' },
];
---

<header class="border-b border-stone-200 bg-white/90 backdrop-blur-sm sticky top-0 z-10 shadow-sm">
	<div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-4 flex flex-wrap items-center justify-between gap-4">
		<a href="/" class="flex items-center gap-3 text-stone-900 hover:text-stone-700 transition-colors">
			<img src="/images/logo.png" alt="Stop Sueing Valve" class="h-9 w-auto" width="140" height="36" />
			<span class="text-lg font-semibold tracking-tight hidden sm:inline">Stop Sueing Valve</span>
		</a>
		<nav class="flex items-center gap-6 sm:gap-8" aria-label="Main navigation">
			{navLinks.map((link) => (
				<a
					href={link.href}
					class="text-stone-600 hover:text-stone-900 text-sm font-medium transition-colors"
				>
					{link.label}
				</a>
			))}
		</nav>
	</div>
</header>
