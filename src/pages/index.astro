---
import Layout from '../layouts/Layout.astro';
import LawsuitDropdown from '../components/LawsuitDropdown.astro';
import { lawsuits, getRegionFlag } from '../data/lawsuits';

const regions = [...new Set(lawsuits.map((l) => l.region))].sort();
const filterOptions = [
	{ value: '', label: 'All', flag: '' },
	...regions.map((r) => ({ value: r, label: r, flag: getRegionFlag(r) })),
];
const typeFilterOptions = [
	{ value: '', label: 'All' },
	{ value: 'consumer', label: 'Consumer' },
	{ value: 'developer', label: 'Developer' },
];
---

<Layout title="Stop Suing Valve" description="We inform developers and consumers about collective actions against Valve and how to remove yourself from default-opt-in lawsuits.">
	<article class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-10 sm:py-14 lg:py-20">
		<!-- Hero -->
		<header class="text-center mb-14 sm:mb-20">
			<div class="flex justify-center mb-6">
				<img src="/images/logo.png" alt="Stop Suing Valve" class="h-16 sm:h-20 w-auto" width="200" height="80" />
			</div>
			<h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-stone-900 tracking-tight mb-4">
				Stop Suing Valve
			</h1>
			<p class="text-lg sm:text-xl text-stone-600 leading-relaxed max-w-3xl mx-auto mb-10">
				We inform developers and consumers about collective actions against Valve and how to remove yourself from default-opt-in lawsuits. Choose your path below.
			</p>
			<!-- I'm a consumer / I'm a developer buttons -->
			<div class="flex flex-col sm:flex-row gap-4 justify-center items-stretch sm:items-center">
				<a
					href="#for-consumers"
					class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-lg bg-stone-800 text-white hover:bg-stone-700 transition-colors shadow-md hover:shadow-lg min-h-[56px]"
				>
					I'm a consumer
				</a>
				<a
					href="#for-developers"
					class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-lg border-2 border-stone-800 text-stone-800 hover:bg-stone-100 transition-colors min-h-[56px]"
				>
					I'm a developer
				</a>
			</div>
		</header>

		<!-- Short mission -->
		<section class="mb-14 max-w-3xl mx-auto text-center">
			<p class="text-stone-600 leading-relaxed text-base sm:text-lg">
				Stop Suing Valve is a campaign to inform you about lawsuits such as the UK Steam You Owe Us claim and the US Valve Antitrust class action. We believe these suits misuse competition and consumer law and can harm the ecosystem. We do not support harassment of any company or person; we only provide factual information and opt-out options.
			</p>
		</section>

		<!-- Lawsuits: one dropdown per lawsuit -->
		<section class="mb-14 text-center" id="lawsuits">
			<span id="for-consumers" class="block scroll-mt-24" aria-hidden="true" />
			<span id="for-developers" class="block scroll-mt-24" aria-hidden="true" />
			<h2 class="text-xl sm:text-2xl font-semibold text-stone-900 mb-6">Claims & lawsuits</h2>
			<p class="text-stone-600 leading-relaxed mb-6 max-w-3xl mx-auto">
				Expand a lawsuit below to read what it is, who it affects, and—where applicable—how to remove yourself from default-opt-in classes.
			</p>
			<!-- Country filter -->
			<div class="flex flex-wrap justify-center gap-2 mb-3 text-left" role="group" aria-label="Filter by country">
				{filterOptions.map((opt) => (
					<button
						type="button"
						class="lawsuit-filter-btn lawsuit-filter-region px-4 py-2 rounded-lg text-sm font-medium border-2 transition-colors"
						data-filter={opt.value}
						class:list={[
							opt.value === ''
								? 'border-stone-700 bg-stone-700 text-white'
								: 'border-stone-200 text-stone-700 hover:bg-stone-100',
						]}
					>
						{opt.flag && <span class="mr-1.5" aria-hidden="true">{opt.flag}</span>}
						{opt.value === '' ? 'All' : opt.label}
					</button>
				))}
			</div>
			<!-- Type filter (consumer / developer) -->
			<div class="flex flex-wrap justify-center gap-2 mb-6 text-left" role="group" aria-label="Filter by type">
				{typeFilterOptions.map((opt) => (
					<button
						type="button"
						class="lawsuit-filter-btn lawsuit-filter-type px-4 py-2 rounded-lg text-sm font-medium border-2 transition-colors"
						data-filter={opt.value}
						class:list={[
							opt.value === ''
								? 'border-stone-700 bg-stone-700 text-white'
								: 'border-stone-200 text-stone-700 hover:bg-stone-100',
						]}
					>
						{opt.label}
					</button>
				))}
			</div>
			<div class="space-y-4 text-left" id="lawsuits-list">
				{lawsuits.map((lawsuit) => (
					<div
						class="scroll-mt-24 lawsuit-item transition-opacity duration-200"
						id={`lawsuit-${lawsuit.id}`}
						data-region={lawsuit.region}
						data-audience={lawsuit.audience}
					>
						<LawsuitDropdown lawsuit={lawsuit} />
					</div>
				))}
			</div>
			<p id="no-results-message" class="text-center text-stone-600 py-6 hidden" role="status">
				No lawsuits match the selected filters. Try changing the country or type above.
			</p>
		</section>

		<!-- Disclaimers: funding, about, voluntary merged and centered -->
		<section id="no-funding" class="text-center text-stone-600 leading-relaxed max-w-2xl mx-auto space-y-6">
			<div>
				<p>
					<strong class="text-stone-800">We are not seeking funding.</strong> We do not ask for donations or paid sign-ups. Any claims of fundraising in our name are not from us. <strong class="text-stone-800">This site is <a href="https://github.com/StopSuingValve/ssv-website" target="_blank" rel="noopener noreferrer" class="underline hover:no-underline">open source</a></strong> and was made with AI. We welcome voluntary contributions—share the site, give feedback, or submit a pull request.
				</p>
				<p class="mt-4 flex flex-wrap items-center justify-center gap-x-3 gap-y-2">
					<a href="https://discord.gg/R92WaMkeJN" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-stone-800 font-medium hover:text-stone-600 transition-colors">
						<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
						</svg>
						Discord
					</a>
					<span class="text-stone-300">·</span>
					<a href="https://github.com/StopSuingValve/ssv-website" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-stone-800 font-medium hover:text-stone-600 transition-colors">
						<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
						</svg>
						GitHub
					</a>
					<span class="text-stone-300">·</span>
					<a href="mailto:contact@stopsuingvalve.com" class="text-stone-800 font-medium hover:text-stone-600 transition-colors">contact@stopsuingvalve.com</a>
				</p>
			</div>
		</section>
	</article>

	<script>
		(function () {
			const list = document.getElementById('lawsuits-list');
			const regionButtons = document.querySelectorAll('.lawsuit-filter-region');
			const typeButtons = document.querySelectorAll('.lawsuit-filter-type');
			const items = document.querySelectorAll('.lawsuit-item');
			if (!list || !regionButtons.length || !typeButtons.length || !items.length) return;

			let regionFilter = '';
			let typeFilter = '';

			function setActiveButtons() {
				regionButtons.forEach((btn) => {
					const value = btn.dataset.filter ?? '';
					btn.setAttribute('aria-pressed', value === regionFilter ? 'true' : 'false');
					btn.classList.remove('border-stone-700', 'bg-stone-700', 'text-white', 'border-stone-200', 'text-stone-700', 'hover:bg-stone-100');
					if (value === regionFilter) {
						btn.classList.add('border-stone-700', 'bg-stone-700', 'text-white');
					} else {
						btn.classList.add('border-stone-200', 'text-stone-700', 'hover:bg-stone-100');
					}
				});
				typeButtons.forEach((btn) => {
					const value = btn.dataset.filter ?? '';
					btn.setAttribute('aria-pressed', value === typeFilter ? 'true' : 'false');
					btn.classList.remove('border-stone-700', 'bg-stone-700', 'text-white', 'border-stone-200', 'text-stone-700', 'hover:bg-stone-100');
					if (value === typeFilter) {
						btn.classList.add('border-stone-700', 'bg-stone-700', 'text-white');
					} else {
						btn.classList.add('border-stone-200', 'text-stone-700', 'hover:bg-stone-100');
					}
				});
			}

			function filterItems() {
				setActiveButtons();
				let visibleCount = 0;
				items.forEach((el) => {
					const region = el.dataset.region ?? '';
					const audience = el.dataset.audience ?? '';
					const regionMatch = regionFilter === '' || region === regionFilter;
					const typeMatch =
						typeFilter === '' ||
						audience === typeFilter ||
						(audience === 'both' && (typeFilter === 'consumer' || typeFilter === 'developer'));
					const show = regionMatch && typeMatch;
					el.hidden = !show;
					if (show) visibleCount++;
				});
				const noResults = document.getElementById('no-results-message');
				if (noResults) {
					noResults.classList.toggle('hidden', visibleCount > 0);
				}
			}

			regionButtons.forEach((btn) => {
				btn.addEventListener('click', () => {
					regionFilter = btn.dataset.filter ?? '';
					filterItems();
				});
			});
			typeButtons.forEach((btn) => {
				btn.addEventListener('click', () => {
					typeFilter = btn.dataset.filter ?? '';
					filterItems();
				});
			});

			function openLawsuitFromHash() {
				const id = decodeURIComponent(location.hash.slice(1));
				if (!id || !id.startsWith('lawsuit-')) return;
				const el = document.getElementById(id);
				if (!el || !el.classList.contains('lawsuit-item')) return;

				regionFilter = '';
				typeFilter = '';
				filterItems();

				const details = el.querySelector('details');
				if (details) {
					details.open = true;
					requestAnimationFrame(() => {
						el.scrollIntoView({ behavior: 'smooth', block: 'start' });
					});
				}
			}

			filterItems();
			openLawsuitFromHash();
			window.addEventListener('hashchange', openLawsuitFromHash);
		})();
	</script>

	<!-- Newsletter Modal -->
	<dialog id="newsletter-modal" class="fixed inset-0 z-50 w-full max-w-lg mx-auto my-auto p-0 bg-transparent backdrop:bg-black/50 backdrop:backdrop-blur-sm">
		<div class="bg-white rounded-xl shadow-xl p-6 sm:p-8 relative">
			<button type="button" id="newsletter-modal-close" class="absolute top-4 right-4 text-stone-400 hover:text-stone-600 transition-colors" aria-label="Close">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
				</svg>
			</button>

			<h2 class="text-xl sm:text-2xl font-semibold text-stone-900 mb-2 text-center">Stay Updated</h2>
			<p class="text-stone-600 text-center mb-6">
				Subscribe to receive updates about this lawsuit, opt-out deadlines, and news.
			</p>

			<!-- Success message (hidden by default) -->
			<div id="newsletter-success" class="hidden text-center py-8">
				<div class="text-green-600 mb-2">
					<svg class="w-12 h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
					</svg>
				</div>
				<h3 class="text-lg font-semibold text-stone-900 mb-1">You're subscribed!</h3>
				<p class="text-stone-600 text-sm">Please check your email to confirm your subscription.</p>
			</div>

			<!-- Form -->
			<form id="newsletter-form" class="listmonk-form space-y-4">
				<div>
					<label for="newsletter-email" class="sr-only">Email address</label>
					<input
						type="email"
						name="email"
						id="newsletter-email"
						required
						placeholder="Email address *"
						class="w-full px-4 py-3 border border-stone-300 rounded-lg text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-stone-500 focus:border-transparent transition-shadow"
					/>
				</div>

				<div>
					<label for="newsletter-name" class="sr-only">Name (optional)</label>
					<input
						type="text"
						name="name"
						id="newsletter-name"
						placeholder="Name (optional)"
						class="w-full px-4 py-3 border border-stone-300 rounded-lg text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-stone-500 focus:border-transparent transition-shadow"
					/>
				</div>

				<fieldset class="space-y-2">
					<legend class="text-sm font-medium text-stone-700 mb-2">Subscribe to:</legend>
					<div class="grid sm:grid-cols-2 gap-2">
						<label class="newsletter-list-label flex items-center gap-2 text-sm text-stone-600 cursor-pointer" data-list="consumer">
							<input type="checkbox" name="l" value="3a77b273-4615-4e1b-9971-403c9b015ad6" class="newsletter-list w-4 h-4 rounded border-stone-300 text-stone-700 focus:ring-stone-500" />
							Consumer Updates
						</label>
						<label class="newsletter-list-label flex items-center gap-2 text-sm text-stone-600 cursor-pointer" data-list="developer">
							<input type="checkbox" name="l" value="ab148fcd-5b2e-4daf-95a0-d55293f43bb6" class="newsletter-list w-4 h-4 rounded border-stone-300 text-stone-700 focus:ring-stone-500" />
							Developer Updates
						</label>
						<label class="newsletter-list-label flex items-center gap-2 text-sm text-stone-600 cursor-pointer" data-list="us">
							<input type="checkbox" name="l" value="fce9a0e1-04c9-405c-89d7-a6134d679b80" class="newsletter-list w-4 h-4 rounded border-stone-300 text-stone-700 focus:ring-stone-500" />
							US Lawsuit Updates
						</label>
						<label class="newsletter-list-label flex items-center gap-2 text-sm text-stone-600 cursor-pointer" data-list="uk">
							<input type="checkbox" name="l" value="3ca8297e-93ca-4073-914b-64098a2b47ae" class="newsletter-list w-4 h-4 rounded border-stone-300 text-stone-700 focus:ring-stone-500" />
							UK Lawsuit Updates
						</label>
						<label class="newsletter-list-label flex items-center gap-2 text-sm text-stone-600 cursor-pointer sm:col-span-2" data-list="new">
							<input type="checkbox" name="l" value="0ba81524-eeef-4a47-9d9a-00d7d4dacdbd" class="newsletter-list w-4 h-4 rounded border-stone-300 text-stone-700 focus:ring-stone-500" />
							New Lawsuits
						</label>
					</div>
				</fieldset>

				<div class="altcha-container">
					<altcha-widget id="altcha-widget" name="altcha" challengeurl="https://mailing.stopsuingvalve.com/api/public/captcha/altcha"></altcha-widget>
					<script async defer src="https://cdn.jsdelivr.net/npm/altcha/dist/altcha.min.js" type="module"></script>
				</div>

				<!-- Error message -->
				<p id="newsletter-error" class="hidden text-red-600 text-sm text-center"></p>

				<p class="text-xs text-stone-500 text-center">
					By subscribing, you agree to our <a href="/privacy" class="underline hover:no-underline">Privacy Policy</a> and <a href="/terms" class="underline hover:no-underline">Terms of Service</a>.
				</p>

				<button
					type="submit"
					id="newsletter-submit"
					class="w-full px-6 py-3 bg-stone-800 text-white font-semibold rounded-lg hover:bg-stone-700 transition-colors shadow-sm hover:shadow-md disabled:opacity-50 disabled:cursor-not-allowed"
				>
					Subscribe
				</button>
			</form>
		</div>
	</dialog>

	<script>
		(function() {
			const modal = document.getElementById('newsletter-modal');
			const closeBtn = document.getElementById('newsletter-modal-close');
			const form = document.getElementById('newsletter-form');
			const successEl = document.getElementById('newsletter-success');
			const errorEl = document.getElementById('newsletter-error');
			const submitBtn = document.getElementById('newsletter-submit');
			const listLabels = document.querySelectorAll('.newsletter-list-label');
			const listCheckboxes = document.querySelectorAll('.newsletter-list');

			if (!modal || !form || !successEl || !errorEl || !submitBtn) return;

			// Track ALTCHA verification state
			let altchaPayloadValue = '';

			// Wait for the widget to be defined, then listen for events
			customElements.whenDefined('altcha-widget').then(() => {
				const altchaWidget = document.getElementById('altcha-widget');
				if (altchaWidget) {
					altchaWidget.addEventListener('statechange', (e) => {
						if (e.detail && e.detail.state === 'verified') {
							altchaPayloadValue = e.detail.payload || altchaWidget.value || '';
						}
					});
				}
			});

			// Open modal with pre-selected lists
			window.openNewsletterModal = function(region, audience) {
				// Reset form state
				form.classList.remove('hidden');
				successEl.classList.add('hidden');
				errorEl.classList.add('hidden');
				form.reset();
				altchaPayloadValue = '';

				// If no region specified (general subscribe), select all lists
				const selectAll = !region;

				// Configure checkboxes based on region and audience
				// Pre-select relevant lists, but keep all enabled for user choice
				listLabels.forEach(label => {
					const checkbox = label.querySelector('input[type="checkbox"]');
					const listType = label.dataset.list;
					
					let shouldCheck = selectAll; // If general subscribe, check all by default

					if (!selectAll) {
						// Region-based list (US/UK lawsuit updates)
						if (listType === 'us' || listType === 'uk') {
							if (listType === region.toLowerCase()) {
								shouldCheck = true;
							}
						}
						// Audience-based list (consumer/developer)
						else if (listType === 'consumer' || listType === 'developer') {
							if (audience === 'both' || audience === listType) {
								shouldCheck = true;
							}
						}
						// New lawsuits - not pre-checked for specific lawsuit
						else if (listType === 'new') {
							shouldCheck = false;
						}
					}

					checkbox.checked = shouldCheck;
					checkbox.disabled = false;
					label.classList.remove('opacity-50');
				});

				modal.showModal();
			};

			// Close modal
			closeBtn?.addEventListener('click', () => modal.close());
			modal.addEventListener('click', (e) => {
				if (e.target === modal) modal.close();
			});

			// Form submission
			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				
				errorEl.classList.add('hidden');
				errorEl.textContent = '';

				const email = document.getElementById('newsletter-email').value.trim();
				const name = document.getElementById('newsletter-name').value.trim();
				const lists = Array.from(document.querySelectorAll('.newsletter-list:checked')).map(cb => cb.value);

				if (!email) {
					errorEl.textContent = 'Please enter your email address.';
					errorEl.classList.remove('hidden');
					return;
				}

				if (lists.length === 0) {
					errorEl.textContent = 'Please select at least one mailing list.';
					errorEl.classList.remove('hidden');
					return;
				}

				// Get ALTCHA payload
				let altchaPayload = altchaPayloadValue;
				if (!altchaPayload) {
					const altchaWidget = document.getElementById('altcha-widget');
					if (altchaWidget) altchaPayload = altchaWidget.value || '';
				}
				if (!altchaPayload) {
					const altchaInput = form.querySelector('input[name="altcha"]');
					if (altchaInput) altchaPayload = altchaInput.value || '';
				}

				if (!altchaPayload) {
					errorEl.textContent = 'Please click the verification checkbox and wait for it to complete.';
					errorEl.classList.remove('hidden');
					return;
				}

				submitBtn.disabled = true;
				submitBtn.textContent = 'Subscribing...';

				try {
					const response = await fetch('https://mailing.stopsuingvalve.com/api/public/subscription', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							email: email,
							name: name || undefined,
							list_uuids: lists,
							captcha: altchaPayload
						})
					});

					const data = await response.json().catch(() => ({}));

					if (response.ok) {
						form.classList.add('hidden');
						successEl.classList.remove('hidden');
					} else {
						throw new Error(data.message || 'Subscription failed. Please try again.');
					}
				} catch (err) {
					errorEl.textContent = err.message || 'Something went wrong. Please try again.';
					errorEl.classList.remove('hidden');
				} finally {
					submitBtn.disabled = false;
					submitBtn.textContent = 'Subscribe';
				}
			});
		})();
	</script>
</Layout>
