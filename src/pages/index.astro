---
import Layout from '../layouts/Layout.astro';
import LawsuitDropdown from '../components/LawsuitDropdown.astro';
import { lawsuits, getRegionFlag } from '../data/lawsuits';

const regions = [...new Set(lawsuits.map((l) => l.region))].sort();
const filterOptions = [
	{ value: '', label: 'All', flag: '' },
	...regions.map((r) => ({ value: r, label: r, flag: getRegionFlag(r) })),
];
const typeFilterOptions = [
	{ value: '', label: 'All' },
	{ value: 'consumer', label: 'Consumer' },
	{ value: 'developer', label: 'Developer' },
];
---

<Layout title="Stop Sueing Valve" description="We inform developers and consumers about collective actions against Valve and how to remove yourself from default-opt-in lawsuits.">
	<article class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-10 sm:py-14 lg:py-20">
		<!-- Hero -->
		<header class="text-center mb-14 sm:mb-20">
			<div class="flex justify-center mb-6">
				<img src="/images/logo.png" alt="Stop Sueing Valve" class="h-16 sm:h-20 w-auto" width="200" height="80" />
			</div>
			<h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-stone-900 tracking-tight mb-4">
				Stop Sueing Valve
			</h1>
			<p class="text-lg sm:text-xl text-stone-600 leading-relaxed max-w-3xl mx-auto mb-10">
				We inform developers and consumers about collective actions against Valve and how to remove yourself from default-opt-in lawsuits. Choose your path below.
			</p>
			<!-- I'm a consumer / I'm a developer buttons -->
			<div class="flex flex-col sm:flex-row gap-4 justify-center items-stretch sm:items-center">
				<a
					href="#for-consumers"
					class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-lg bg-stone-800 text-white hover:bg-stone-700 transition-colors shadow-md hover:shadow-lg min-h-[56px]"
				>
					I'm a consumer
				</a>
				<a
					href="#for-developers"
					class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-lg border-2 border-stone-800 text-stone-800 hover:bg-stone-100 transition-colors min-h-[56px]"
				>
					I'm a developer
				</a>
			</div>
		</header>

		<!-- Short mission -->
		<section class="mb-14 max-w-3xl mx-auto text-center">
			<p class="text-stone-600 leading-relaxed text-base sm:text-lg">
				Stop Sueing Valve is a campaign to inform you about lawsuits such as the UK Steam You Owe Us claim and the US Valve Antitrust class action. We believe these suits misuse competition and consumer law and can harm the ecosystem. We do not support harassment of any company or person; we only provide factual information and opt-out options.
			</p>
		</section>

		<!-- Lawsuits: one dropdown per lawsuit -->
		<section class="mb-14 text-center" id="lawsuits">
			<span id="for-consumers" class="block scroll-mt-24" aria-hidden="true" />
			<span id="for-developers" class="block scroll-mt-24" aria-hidden="true" />
			<h2 class="text-xl sm:text-2xl font-semibold text-stone-900 mb-6">Claims & lawsuits</h2>
			<p class="text-stone-600 leading-relaxed mb-6 max-w-3xl mx-auto">
				Expand a lawsuit below to read what it is, who it affects, and—where applicable—how to remove yourself from default-opt-in classes.
			</p>
			<!-- Country filter -->
			<div class="flex flex-wrap justify-center gap-2 mb-3 text-left" role="group" aria-label="Filter by country">
				{filterOptions.map((opt) => (
					<button
						type="button"
						class="lawsuit-filter-btn lawsuit-filter-region px-4 py-2 rounded-lg text-sm font-medium border-2 transition-colors"
						data-filter={opt.value}
						class:list={[
							opt.value === ''
								? 'border-stone-700 bg-stone-700 text-white'
								: 'border-stone-200 text-stone-700 hover:bg-stone-100',
						]}
					>
						{opt.flag && <span class="mr-1.5" aria-hidden="true">{opt.flag}</span>}
						{opt.value === '' ? 'All' : opt.label}
					</button>
				))}
			</div>
			<!-- Type filter (consumer / developer) -->
			<div class="flex flex-wrap justify-center gap-2 mb-6 text-left" role="group" aria-label="Filter by type">
				{typeFilterOptions.map((opt) => (
					<button
						type="button"
						class="lawsuit-filter-btn lawsuit-filter-type px-4 py-2 rounded-lg text-sm font-medium border-2 transition-colors"
						data-filter={opt.value}
						class:list={[
							opt.value === ''
								? 'border-stone-700 bg-stone-700 text-white'
								: 'border-stone-200 text-stone-700 hover:bg-stone-100',
						]}
					>
						{opt.label}
					</button>
				))}
			</div>
			<div class="space-y-4 text-left" id="lawsuits-list">
				{lawsuits.map((lawsuit) => (
					<div
						class="scroll-mt-24 lawsuit-item transition-opacity duration-200"
						id={`lawsuit-${lawsuit.id}`}
						data-region={lawsuit.region}
						data-audience={lawsuit.audience}
					>
						<LawsuitDropdown lawsuit={lawsuit} />
					</div>
				))}
			</div>
			<p id="no-results-message" class="text-center text-stone-600 py-6 hidden" role="status">
				No lawsuits match the selected filters. Try changing the country or type above.
			</p>
		</section>

		<!-- Disclaimers: funding, about, voluntary merged and centered -->
		<section id="no-funding" class="text-center text-stone-600 leading-relaxed max-w-2xl mx-auto space-y-6">
			<div>
				<p>
					<strong class="text-stone-800">We are not seeking funding.</strong> We do not ask for donations or paid sign-ups. Any claims of fundraising in our name are not from us. <strong class="text-stone-800">This site and its logo were made with AI.</strong> We welcome voluntary support—by sharing the site, giving feedback, or contributing. No obligation. Contact: <a href="mailto:contact@stopsueingvalve.com" class="text-stone-800 font-medium underline hover:no-underline">contact@stopsueingvalve.com</a>.
				</p>
			</div>
		</section>
	</article>

	<script>
		(function () {
			const list = document.getElementById('lawsuits-list');
			const regionButtons = document.querySelectorAll('.lawsuit-filter-region');
			const typeButtons = document.querySelectorAll('.lawsuit-filter-type');
			const items = document.querySelectorAll('.lawsuit-item');
			if (!list || !regionButtons.length || !typeButtons.length || !items.length) return;

			let regionFilter = '';
			let typeFilter = '';

			function setActiveButtons() {
				regionButtons.forEach((btn) => {
					const value = btn.dataset.filter ?? '';
					btn.setAttribute('aria-pressed', value === regionFilter ? 'true' : 'false');
					btn.classList.remove('border-stone-700', 'bg-stone-700', 'text-white', 'border-stone-200', 'text-stone-700', 'hover:bg-stone-100');
					if (value === regionFilter) {
						btn.classList.add('border-stone-700', 'bg-stone-700', 'text-white');
					} else {
						btn.classList.add('border-stone-200', 'text-stone-700', 'hover:bg-stone-100');
					}
				});
				typeButtons.forEach((btn) => {
					const value = btn.dataset.filter ?? '';
					btn.setAttribute('aria-pressed', value === typeFilter ? 'true' : 'false');
					btn.classList.remove('border-stone-700', 'bg-stone-700', 'text-white', 'border-stone-200', 'text-stone-700', 'hover:bg-stone-100');
					if (value === typeFilter) {
						btn.classList.add('border-stone-700', 'bg-stone-700', 'text-white');
					} else {
						btn.classList.add('border-stone-200', 'text-stone-700', 'hover:bg-stone-100');
					}
				});
			}

			function filterItems() {
				setActiveButtons();
				let visibleCount = 0;
				items.forEach((el) => {
					const region = el.dataset.region ?? '';
					const audience = el.dataset.audience ?? '';
					const regionMatch = regionFilter === '' || region === regionFilter;
					const typeMatch =
						typeFilter === '' ||
						audience === typeFilter ||
						(audience === 'both' && (typeFilter === 'consumer' || typeFilter === 'developer'));
					const show = regionMatch && typeMatch;
					el.hidden = !show;
					if (show) visibleCount++;
				});
				const noResults = document.getElementById('no-results-message');
				if (noResults) {
					noResults.classList.toggle('hidden', visibleCount > 0);
				}
			}

			regionButtons.forEach((btn) => {
				btn.addEventListener('click', () => {
					regionFilter = btn.dataset.filter ?? '';
					filterItems();
				});
			});
			typeButtons.forEach((btn) => {
				btn.addEventListener('click', () => {
					typeFilter = btn.dataset.filter ?? '';
					filterItems();
				});
			});

			filterItems();
		})();
	</script>
</Layout>
